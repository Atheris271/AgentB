{
  "name": "agent",
  "description": "一个基于 Python 3.10 实现的本地文件驱动 Agent 框架，使用 Qwen3.5-4B 模型进行本地推理。项目包含五个独立模块（B1-B5）：Agent 总控与消息管理、Skill 独立运行、工具层 schema 生成与校验、本地 LLM 推理（支持 mock 与真实模式）、以及记忆文档的查找与索引维护。",
  "languages": ["csv", "json", "markdown", "python", "txt", "unknown", "yaml"],
  "frameworks": ["HuggingFace Transformers", "PyTorch"],
