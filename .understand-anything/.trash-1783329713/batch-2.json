      "tags": ["utility", "path-resolution", "sandbox", "common"],
      "complexity": "simple",
      "languageNotes": "PROJECT_ROOT 通过 __file__ 向上两级推导，bootstrap_project_root 将项目根注入 sys.path 实现无安装导入。"
    },
